# install and path files to ignore for Python projects
*install*
*patch*
*temp*
*migrate*
*~backup*
~*
.~*
build*
*us_*_*.json
diagnose*.py

# old Knowledge_Transfer files
knowledge_transfers/

# Byte-compiled / optimized / DLL files
__pycache__/
*cache
*.py[cod]
*$py.class

# Extras
auxiliary/
examples/
older/
legacy*/
prices*/

# Python extras
*egg*/

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
../*

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Translations
*.mo
*.pot

# Office documents
*.odt
*.ods
*.docx
*.xlsx
*.pptx
*.csv
